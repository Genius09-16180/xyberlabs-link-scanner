# ─────────────────────────────────────────────────────────
#  XyberLabs Link Scanner AI — Environment Variables
#  Rinomina in .env e compila con i tuoi valori reali
# ─────────────────────────────────────────────────────────

# Porta del server (Render la imposta automaticamente)
PORT=3001

# La tua API key Groq — ottienila gratis su https://console.groq.com
GROQ_API_KEY=gsk_INSERISCI_QUI_LA_TUA_CHIAVE_GROQ

# MongoDB Atlas connection string — crea cluster free su https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://UTENTE:PASSWORD@cluster0.XXXXX.mongodb.net/xyberlabs_scanner?retryWrites=true&w=majority

# Origini CORS permesse (il tuo dominio frontend su Netlify/Vercel)
# Esempio: https://xyberlabs-scanner.netlify.app
FRONTEND_URL=http://localhost:5173

# Chiave segreta per rate limiting e firme interne (genera con: openssl rand -hex 32)
SECRET_KEY=GENERA_UNA_CHIAVE_SICURA_QUI
